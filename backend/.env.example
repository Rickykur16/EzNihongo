# Copy this to .env on VPS and fill in real values
# NEVER commit .env (it's in .gitignore)

# --- Server ---
PORT=3001
NODE_ENV=production

# --- Database (localhost only on VPS) ---
DATABASE_URL=postgresql://eznihongo_app:REPLACE_WITH_REAL_PASSWORD@localhost:5432/eznihongo

# --- JWT (generate with: openssl rand -base64 64) ---
JWT_ACCESS_SECRET=REPLACE_WITH_RANDOM_64_CHARS
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_RANDOM_64_CHARS

# --- Google OAuth (from Google Cloud Console) ---
GOOGLE_CLIENT_ID=REPLACE_WITH_GOOGLE_CLIENT_ID.apps.googleusercontent.com

# --- Admin access (comma-separated emails) ---
ADMIN_EMAILS=rickysatoru@gmail.com

# --- CORS ---
ALLOWED_ORIGINS=https://eznihongo.com,https://www.eznihongo.com

# --- Cookie config ---
COOKIE_DOMAIN=.eznihongo.com
COOKIE_SECURE=true
