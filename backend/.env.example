# Copy this to .env on VPS and fill in real values
# NEVER commit .env (it's in .gitignore)

# --- Server ---
PORT=3001
NODE_ENV=production

# --- Database (localhost only on VPS) ---
DATABASE_URL=postgresql://eznihongo_app:REPLACE_WITH_REAL_PASSWORD@localhost:5432/eznihongo

# --- JWT (generate with: openssl rand -base64 64) ---
JWT_ACCESS_SECRET=REPLACE_WITH_RANDOM_64_CHARS
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_RANDOM_64_CHARS

# --- Google OAuth (from Google Cloud Console) ---
GOOGLE_CLIENT_ID=REPLACE_WITH_GOOGLE_CLIENT_ID.apps.googleusercontent.com

# --- Admin access (comma-separated emails) ---
ADMIN_EMAILS=rickysatoru@gmail.com

# --- CORS ---
# Include https://app.eznihongo.com so the Kanji PWA can call /api.
ALLOWED_ORIGINS=https://eznihongo.com,https://www.eznihongo.com,https://app.eznihongo.com

# --- Cookie config ---
COOKIE_DOMAIN=.eznihongo.com
COOKIE_SECURE=true

# --- Midtrans (Kanji PWA subscription) ---
# Sandbox: app.sandbox.midtrans.com. Production: app.midtrans.com.
MIDTRANS_BASE=https://app.sandbox.midtrans.com
MIDTRANS_SERVER_KEY=SB-Mid-server-REPLACE_ME
# Client key is exposed in kanji.html (inject via template or hard-code).
MIDTRANS_CLIENT_KEY=SB-Mid-client-REPLACE_ME
# Used for the Snap `finish` callback URL.
APP_URL=https://app.eznihongo.com
